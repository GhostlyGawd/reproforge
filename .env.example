# Optional. The bundled golden path remains offline even when this is configured.
OPENAI_API_KEY=

# ReproForge runtime mode: offline, test, preview, or production. Leave empty
# for local offline development. Hosted modes fail closed unless every required
# Milestone 8A provider value is present.
REPROFORGE_RUNTIME_MODE=
REPROFORGE_BASE_URL=

# Hosted durable-state providers. Keep real values in .env.local or scoped
# Vercel environment variables; never commit them.
DATABASE_URL=
# Used only by the isolated live backup/restore drill so each side can select a
# temporary schema. The hosted application continues to use DATABASE_URL.
DATABASE_URL_UNPOOLED=
# Preferred on Vercel: connect the private Blob store to the project so these
# short-lived OIDC values are populated and rotated by the platform.
BLOB_STORE_ID=
VERCEL_OIDC_TOKEN=
# Off-platform/local fallback only. Hosted config accepts this when the OIDC
# pair above is absent.
BLOB_READ_WRITE_TOKEN=

# Bounded production policies. Empty values use the documented safe defaults.
# Queue authentication is platform-managed OIDC; users never supply a ChatGPT
# or OpenAI API key for the plugin path.
REPROFORGE_JOB_LEASE_SECONDS=
REPROFORGE_MAX_ACTIVE_JOBS_PER_TENANT=
REPROFORGE_MAX_DELIVERY_ATTEMPTS=
REPROFORGE_OUTBOX_BATCH_SIZE=
REPROFORGE_OUTBOX_CLAIM_SECONDS=
REPROFORGE_QUEUE_REGION=
REPROFORGE_QUEUE_RETENTION_SECONDS=
REPROFORGE_QUEUE_TOPIC=
REPROFORGE_RETENTION_DAYS=

# Emergency feature kill switches. Values are schema-closed and fail startup
# unless they are exactly `true` or `false`. Disabled profiles are a comma-
# separated set containing only `node22` and/or `node24`.
REPROFORGE_DISABLE_REPOSITORY_STARTS=false
REPROFORGE_DISABLE_PRIVATE_REPOSITORIES=false
REPROFORGE_DISABLED_EXECUTION_PROFILES=

# Auth0 protects the MCP resource and the web account session. The namespaced
# tenant claim must be issued by a reviewed Auth0 Action; browser and ChatGPT
# clients never receive provider credentials from ReproForge.
APP_BASE_URL=
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_SECRET=
REPROFORGE_OAUTH_TENANT_CLAIM=

# Set only while the OpenAI plugin submission portal is verifying this exact
# production hostname. The well-known route is a 404 when this is empty.
OPENAI_APPS_CHALLENGE_TOKEN=

# Read-only GitHub App trust boundary. Keep the PKCS#8 key, OAuth client secret,
# and webhook secret in server-only environment variables. Installation and
# user access tokens are minted transiently and are never configured here.
GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# Live provider verification is intentionally enabled by `npm run
# test:providers`; do not set its internal gate flag in normal application
# environments. See docs/operations.md.
