# Optional. The bundled golden path remains offline even when this is configured.
OPENAI_API_KEY=

# ReproForge runtime mode: offline, test, preview, or production. Leave empty
# for local offline development. Hosted modes fail closed unless every required
# Milestone 8A provider value is present.
REPROFORGE_RUNTIME_MODE=
REPROFORGE_BASE_URL=

# Hosted durable-state providers. Keep real values in .env.local or scoped
# Vercel environment variables; never commit them.
DATABASE_URL=
# Preferred on Vercel: connect the private Blob store to the project so these
# short-lived OIDC values are populated and rotated by the platform.
BLOB_STORE_ID=
VERCEL_OIDC_TOKEN=
# Off-platform/local fallback only. Hosted config accepts this when the OIDC
# pair above is absent.
BLOB_READ_WRITE_TOKEN=

# Bounded production policies. Empty values use the documented safe defaults.
REPROFORGE_JOB_LEASE_SECONDS=
REPROFORGE_MAX_ACTIVE_JOBS_PER_TENANT=
REPROFORGE_RETENTION_DAYS=
